{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Quiz Question Bank",
  "description": "统一的题库 JSON 格式，用于所有考试科目的题库文件",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "chapter", "stem", "options", "answer", "analysis"],
    "properties": {
      "id": {
        "type": "string",
        "description": "唯一标识，格式为 {subject}-{number}，如 laws-001"
      },
      "chapter": {
        "type": "number",
        "description": "章节编号"
      },
      "stem": {
        "type": "string",
        "description": "题目内容"
      },
      "options": {
        "type": "array",
        "items": { "type": "string" },
        "minItems": 4,
        "maxItems": 4,
        "description": "四个选项，格式为 \"A. 选项内容\""
      },
      "answer": {
        "type": "string",
        "enum": ["A", "B", "C", "D"],
        "description": "正确答案的选项字母"
      },
      "analysis": {
        "type": "string",
        "description": "解析内容"
      },
      "isKey": {
        "type": "boolean",
        "description": "是否高频考点"
      }
    }
  }
}
